{
  "name": "@neongreen/codebox",
  "version": "0.1.0",
  "description": "Xcode-style React code blocks: Shiki highlighting + indent-aware soft wrapping that survives malformed syntax.",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./styles.css": "./src/styles.css"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "demo:dev": "vite demo",
    "demo:build": "vite build demo",
    "demo:preview": "vite preview demo"
  },
  "keywords": [
    "react",
    "code",
    "syntax-highlighting",
    "shiki",
    "code-block",
    "indent",
    "word-wrap",
    "xcode"
  ],
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "shiki": "^3.0.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.2",
    "puppeteer-core": "^25.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.6.0",
    "vite": "^8.0.16"
  }
}
